PUBLIC_API_BASE_URL=http://localhost:8787

# CORS: comma-separated browser origins allowed to call the API (default includes Vite :5173 + Next :3000)
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: LLM parsing (OpenAI-compatible — includes Gemini via OpenAI compat URL)
# Put this file in server/.env (not the monorepo root).
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
# Gemini (Google AI Studio): use your API key above and e.g.:
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# OPENAI_MODEL=gemini-2.5-flash

# Optional: in-memory cache for successful LLM parses (same text + model + base URL = no API call)
# PARSE_LLM_CACHE_MAX=500
# PARSE_LLM_CACHE_TTL_MS=86400000
# Set to 0 for time-based expiry off (eviction by max size only)
# PARSE_LLM_CACHE_DISABLE=1

# Optional: Slack Bolt (Socket Mode example)
SLACK_ENABLE=0
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_APP_TOKEN=xapp-your-app-token
# For HTTP mode instead, configure signing secret + process URL in Slack app
